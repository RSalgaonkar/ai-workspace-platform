generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String               @id @default(cuid())
  name          String
  email         String               @unique
  password      String
  role          String               @default("USER")
  refreshToken  String?

  ownedWorkspaces Workspace[]          @relation("WorkspaceOwner")
  workspaces       WorkspaceMember[]
  messages      Message[]
  reactions     MessageReaction[]
  uploadedFiles FileAsset[]          @relation("UploadedFiles")
  documentRevisions DocumentRevision[]
  activities    Activity[]
  notificationPreferences NotificationPreference[]
  notificationDeliveries NotificationDelivery[]
  notifications Notification[]

  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model Workspace {
  id          String               @id @default(cuid())

  name        String
  slug        String               @unique
  description String?
  avatarUrl   String?
  avatarColor String               @default("#0f172a")
  settings    Json?

  ownerId     String
  owner       User                 @relation("WorkspaceOwner", fields: [ownerId], references: [id])

  members     WorkspaceMember[]
  channels    Channel[]
  invites     Invite[]
  files       FileAsset[]
  documents   CollaborativeDocument[]
  activities  Activity[]
  customRoles CustomRole[]
  channelPermissions ChannelPermission[]
  notificationPreferences NotificationPreference[]
  notificationDeliveries NotificationDelivery[]
  searchIndex SearchIndex[]

  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model WorkspaceMember {
  id          String      @id @default(cuid())

  userId      String
  workspaceId String

  role        WorkspaceRole @default(MEMBER)
  permissions Json?
  customRoleId String?

  user        User        @relation(fields: [userId], references: [id])

  workspace   Workspace   @relation(fields: [workspaceId], references: [id])
  customRole  CustomRole? @relation(fields: [customRoleId], references: [id])

  createdAt   DateTime    @default(now())

  @@unique([userId, workspaceId])
}

model Channel {
  id          String      @id @default(cuid())

  name        String
  description String?
  position    Int         @default(0)

  workspaceId String

  workspace   Workspace   @relation(fields: [workspaceId], references: [id])

  messages    Message[]
  permissions ChannelPermission[]

  createdAt   DateTime    @default(now())
}

model CustomRole {
  id          String      @id @default(cuid())
  name        String
  description String?
  permissions Json
  workspaceId String

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members     WorkspaceMember[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([workspaceId, name])
}

model ChannelPermission {
  id          String      @id @default(cuid())
  channelId   String
  workspaceId String
  role        WorkspaceRole?
  customRoleId String?
  permissions Json

  channel     Channel     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Message {
  id          String      @id @default(cuid())

  content     String

  channelId   String
  userId      String
  parentId    String?

  channel     Channel     @relation(fields: [channelId], references: [id])

  user        User        @relation(fields: [userId], references: [id])
  parent      Message?    @relation("MessageThread", fields: [parentId], references: [id])
  replies     Message[]   @relation("MessageThread")
  attachments MessageAttachment[]
  reactions   MessageReaction[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now()) @updatedAt
}

model FileAsset {
  id          String      @id @default(cuid())
  fileName    String
  mimeType    String
  size        Int
  url         String
  storageKey  String

  workspaceId String?
  uploaderId  String

  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  uploader    User       @relation("UploadedFiles", fields: [uploaderId], references: [id])
  messages    MessageAttachment[]

  createdAt   DateTime   @default(now())
}

model MessageAttachment {
  id          String    @id @default(cuid())
  messageId   String
  fileId      String

  message     Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  file        FileAsset @relation(fields: [fileId], references: [id])

  createdAt   DateTime  @default(now())

  @@unique([messageId, fileId])
}

model MessageReaction {
  id          String    @id @default(cuid())
  emoji       String
  messageId   String
  userId      String

  message     Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])

  createdAt   DateTime  @default(now())

  @@unique([messageId, userId, emoji])
}

model CollaborativeDocument {
  id          String      @id @default(cuid())
  title       String
  content     String      @default("")
  workspaceId String

  workspace   Workspace   @relation(fields: [workspaceId], references: [id])
  revisions   DocumentRevision[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model DocumentRevision {
  id          String      @id @default(cuid())
  documentId  String
  authorId    String
  content     String
  version     Int

  document    CollaborativeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author      User                  @relation(fields: [authorId], references: [id])

  createdAt   DateTime    @default(now())

  @@unique([documentId, version])
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  title       String
  metadata    Json?

  workspaceId String?
  actorId     String?

  workspace   Workspace?   @relation(fields: [workspaceId], references: [id])
  actor       User?        @relation(fields: [actorId], references: [id])

  createdAt   DateTime     @default(now())
}

model NotificationPreference {
  id          String      @id @default(cuid())
  userId      String
  workspaceId String?
  emailEnabled Boolean   @default(true)
  pushEnabled  Boolean   @default(false)
  digestEnabled Boolean  @default(true)
  digestFrequency DigestFrequency @default(DAILY)
  mutedChannels Json?

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([userId, workspaceId])
}

model NotificationDelivery {
  id          String      @id @default(cuid())
  userId      String
  workspaceId String?
  channel     NotificationChannel
  subject     String
  body        String
  status      NotificationStatus @default(PENDING)
  metadata    Json?
  sentAt      DateTime?

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt   DateTime   @default(now())
}

model SearchIndex {
  id          String      @id @default(cuid())
  workspaceId String
  entityType  SearchEntityType
  entityId    String
  title       String
  body        String
  keywords    String[]
  embedding   Json?
  metadata    Json?

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([workspaceId, entityType, entityId])
}

model Invite {
  id          String      @id @default(cuid())

  email       String

  token       String      @unique
  role        WorkspaceRole @default(MEMBER)
  status      InviteStatus  @default(PENDING)

  workspaceId String

  workspace   Workspace   @relation(fields: [workspaceId], references: [id])

  expiresAt   DateTime

  createdAt   DateTime    @default(now())
}

model Notification {
  id          String      @id @default(cuid())

  title       String

  content     String

  read        Boolean     @default(false)

  userId      String

  user        User        @relation(fields: [userId], references: [id])

  createdAt   DateTime    @default(now())
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum ActivityType {
  MESSAGE_CREATED
  FILE_UPLOADED
  REACTION_ADDED
  DOCUMENT_UPDATED
  WORKSPACE_UPDATED
  AI_ASSISTANT_USED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum DigestFrequency {
  DAILY
  WEEKLY
}

enum NotificationChannel {
  EMAIL
  PUSH
  IN_APP
  DIGEST
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum SearchEntityType {
  MESSAGE
  DOCUMENT
  FILE
  WORKSPACE
}
